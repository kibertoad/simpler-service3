# Placeholder values for static `kubectl kustomize` rendering in CI.
# Real values are written into ./.env at deploy time by Kargo via Vault
# (see .kargo.yml secrets.vault.envFolder). DO NOT put real secrets here.
#
# The `app` (Hono) Deployment envFrom this Secret.

# --- Hono app ---
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# Base URL for any external HTTP dependency. Overridden with the real upstream
# in production; points at a mock host locally/in CI.
EXTERNAL_API_BASE_URL=http://placeholder

# --- Valkey (cache) ---
REDIS_HOST=valkey
REDIS_PORT=6379
